# Forgejo Actions Runner Registration Token
# Generate this at: https://kalameet/admin/actions
RUNNER_TOKEN=your_runner_token_here

# GitHub to Forgejo Migration
# Your GitHub username
GITHUB_USERNAME=your_github_username
# GitHub personal access token (needs repo scope)
GITHUB_TOKEN=ghp_your_github_token_here
# Forgejo instance URL
FORGEJO_URL=https://kalameet
# Forgejo personal access token (needs write:repository scope)
FORGEJO_TOKEN=your_forgejo_token_here
# Include forked repositories (optional)
# INCLUDE_FORKS=true
# Path to CA certificate for self-signed certs (auto-detected if caddy-ca.crt exists)
# CA_CERT=caddy-ca.crt
# Disable SSL verification (not recommended, use CA_CERT instead)
# VERIFY_SSL=false
